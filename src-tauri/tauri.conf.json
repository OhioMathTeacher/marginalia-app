{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Close Reader",
  "version": "0.1.0",
  "identifier": "com.todd.closereader",
  "mainBinaryName": "close-reader",
  "build": {
    "frontendDist": [
      "../close-reader.html",
      "../plato-play-coordinator.html",
      "../vendor/jszip.min.js",
      "../vendor/mammoth.browser.min.js",
      "../vendor/pdf.min.js",
      "../vendor/pdf.worker.min.js"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Close Reader",
        "url": "close-reader.html",
        "width": 1440,
        "height": 940,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "category": "Education",
    "shortDescription": "Interactive close reading and annotation app.",
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "txt",
          "docx",
          "pdf"
        ],
        "name": "Reading documents",
        "description": "Documents that can be loaded into Close Reader"
      }
    ]
  }
}
